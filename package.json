    "laravel-echo": "^1.16.1",
    "pinia": "^3.0.4",
    "pusher-js": "^8.4.0",
    "vue": "^3.5.31",
    "vue-router": "^5.0.4",
    "vue-sonner": "^2.0.9",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^3.0.0",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-oxlint": "~1.57.0",
    "eslint-plugin-vue": "~10.8.0",
    "globals": "^17.4.0",
    "jsdom": "^26.0.0",
    "npm-run-all2": "^8.0.4",
    "oxlint": "~1.57.0",
    "prettier": "3.8.1",
